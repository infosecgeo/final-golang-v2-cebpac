# AnasFlightsV2 Telegram Bot environment variables
# Copy this file to .env and fill in your values

# REQUIRED: Telegram bot token from @BotFather
BOT_TOKEN=

# REQUIRED: Admin chat/group ID for alert notifications
ADMIN_CHAT_ID=

# REQUIRED: URL of the Go backend
API_URL=http://localhost:5000

# REQUIRED: Shared secret for authenticating API calls to the Go backend
API_KEY=

# REQUIRED: Comma-separated whitelisted Telegram user IDs that can use /admin_help
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# REQUIRED: Private group chat ID where purchase requests are forwarded for approval
PAYMENT_GROUP_ID=

# Optional: Absolute path to the QR code image shown to users when buying credits
QR_CODE_PATH=/path/to/qr-code.jpg

# Optional: Port for the webhook event receiver (Go backend → bot push events)
WEBHOOK_PORT=5100

# Optional: Secret the Go backend must send as X-Webhook-Secret header
WEBHOOK_SECRET=

# Legacy aliases (still supported for backward compatibility)
# PUSA_API_URL=http://localhost:5000
# PUSA_API_KEY=
